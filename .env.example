# Bridge Platform — Master Environment Variables Reference
# Copy this to each service's .env file and customize as needed.

# ── Gateway ──────────────────────────────
STT_URL=http://localhost:8002/speech-to-text
SLR_URL=http://localhost:8006/generate-transcript
TTS_URL=http://localhost:8001/generate-speech
AVATAR_URL=http://localhost:5000/generate-sign-video
AUTH_TOKEN=bridge-dev-token-123

# ── Per-service ports (Railway sets PORT automatically) ──
# PORT=8000   # Gateway
# PORT=8001   # TTS
# PORT=8002   # STT
# PORT=8006   # Sign Recognition
# PORT=5003   # Avatar

# ── TTS ──────────────────────────────────
# BASE_URL=http://localhost:8001

# ── Sign Recognition ─────────────────────
# CHECKPOINT_DIR=./checkpoints_v3
# GROQ_API_KEY=your-groq-api-key

# ── Frontend (Vite) ──────────────────────
# VITE_API_BASE_URL=http://localhost:8000/api
